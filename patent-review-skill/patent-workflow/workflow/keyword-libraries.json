      "algorithm_effect_indicators": {
        "name": "算法效果指标库",
        "description": "算法性能相关指标，属于非技术效果",
        "indicators": [
          {
            "name": "准确率",
            "alias": ["Accuracy", "正确率"],
            "type": "分类",
            "category": "非技术效果"
          },
          {
            "name": "精确率",
            "alias": ["Precision", "查准率"],
            "type": "分类",
            "category": "非技术效果"
          },
          {
            "name": "召回率",
            "alias": ["Recall", "查全率"],
            "type": "分类",
            "category": "非技术效果"
          },
          {
            "name": "F1值",
            "alias": ["F1-Score", "F-Measure"],
            "type": "分类",
            "category": "非技术效果"
          },
          {
            "name": "AUC",
            "alias": ["ROC-AUC", "曲线下面积"],
            "type": "分类",
            "category": "非技术效果"
          },
          {
            "name": "均方误差",
            "alias": ["MSE", "Mean Squared Error"],
            "type": "回归",
            "category": "非技术效果"
          },
          {
            "name": "平均绝对误差",
            "alias": ["MAE", "Mean Absolute Error"],
            "type": "回归",
            "category": "非技术效果"
          },
          {
            "name": "收敛速度",
            "alias": ["Convergence Speed"],
            "type": "优化",
            "category": "非技术效果"
          },
          {
            "name": "迭代次数",
            "alias": ["Iteration Count"],
            "type": "优化",
            "category": "非技术效果"
          },
          {
            "name": "训练时间",
            "alias": ["Training Time"],
            "type": "效率",
            "category": "非技术效果"
          },
          {
            "name": "推理时间",
            "alias": ["Inference Time", "预测时间"],
            "type": "效率",
            "category": "非技术效果"
          },
          {
            "name": "模型参数量",
            "alias": ["Parameters", "模型大小"],
            "type": "规模",
            "category": "非技术效果"
          },
          {
            "name": "内存占用",
            "alias": ["Memory Usage", "显存占用"],
            "type": "资源",
            "category": "需结合判断"
          },
          {
            "name": "聚类效果",
            "alias": ["Clustering Quality", "轮廓系数"],
            "type": "聚类",
            "category": "非技术效果"
          },
          {
            "name": "排序质量",
            "alias": ["Ranking Quality", "NDCG"],
            "type": "排序",
            "category": "非技术效果"
          }
        ]
      },
      "technical_effect_indicators": {
