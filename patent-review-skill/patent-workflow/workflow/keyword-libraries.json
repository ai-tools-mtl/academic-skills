        "strong_binding_signals": {
          "name": "强绑定信号（支持客体）",
          "patterns": [
            "根据.*内存容量.*调整",
            "针对.*图像特性.*设计",
            "利用.*传感器类型.*优化",
            "结合.*信道特性.*处理",
